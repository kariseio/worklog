# ---------------------------------------------------------------------------
# 비밀 값 (git 에 커밋 금지). 이 파일을 `.env` 로 복사한 뒤 값을 채우세요.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# --- NaverWorks (네이버웍스) API 2.0 서비스 계정 ---
# Developer Console 에서 앱 등록 후 발급받는 값들.
NAVERWORKS_CLIENT_ID=
NAVERWORKS_CLIENT_SECRET=
# 서비스 계정 ID (이메일 형식, 예: 46c4...@yourdomain)
NAVERWORKS_SERVICE_ACCOUNT=
# 다운로드한 RSA private key. 파일 경로 또는 인라인 PEM 중 하나만 채우면 됨.
NAVERWORKS_PRIVATE_KEY_PATH=./secrets/private.key
# NAVERWORKS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# 캘린더 소유자(읽을 대상) member ID (이메일 형식). config.yaml 대신 여기에 둬도 됨.
NAVERWORKS_USER_ID=
# 특정 캘린더를 읽을 때만. 비우면 기본 캘린더.
NAVERWORKS_CALENDAR_ID=

# --- Notion ---
# 내부 통합(Integration) 토큰. ntn_... 또는 legacy secret_...
# 대상 페이지/DB 를 이 통합에 "연결(Connections)" 해줘야 함.
NOTION_TOKEN=

# --- Anthropic (선택) ---
# summarizer.provider = anthropic_api 일 때만 필요.
# provider = auto/claude_cli 이면 설치된 `claude` CLI 를 쓰므로 불필요.
ANTHROPIC_API_KEY=
